{
  "name": "requencer",
  "version": "0.1.0",
  "description": "4-track eurorack-style sequencer prototype",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "check": "biome check ./src",
    "fix": "biome check --fix ./src",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "dead-code": "knip"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@vitest/coverage-v8": "^4.0.18",
    "knip": "^5.85.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "tone": "^15.1.22"
  }
}
