  (fp_line (start -4.75 -4.50) (end 4.75 -4.50) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -4.75 4.50) (end 4.75 4.50) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -4.75 -4.50) (end -4.75 4.50) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 4.75 -4.50) (end 4.75 4.50) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (pad "1" thru_hole rect (at -2.50 -2.50) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "2" thru_hole circle (at -1.25 -2.50) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "3" thru_hole circle (at 0.00 -2.50) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "4" thru_hole circle (at 1.25 -2.50) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "5" thru_hole circle (at -1.25 0.00) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "6" thru_hole circle (at 1.25 0.00) (size 1.20 1.20) (drill 0.80) (layers "*.Cu" "*.Mask"))
  (pad "7" thru_hole circle (at 0.00 2.50) (size 1.80 1.80) (drill 1.20) (layers "*.Cu" "*.Mask"))
  (pad "" thru_hole circle (at -3.75 0.00) (size 2.00 2.00) (drill 1.40) (layers "*.Cu" "*.Mask"))
  (pad "" thru_hole circle (at 3.75 0.00) (size 2.00 2.00) (drill 1.40) (layers "*.Cu" "*.Mask"))
