import is_atomic_part
import has_designator_prefix
import has_part_picked

component TPS54331DR:
    trait is_atomic_part<manufacturer="TI", partnumber="TPS54331DR", footprint="SOIC-8.kicad_mod", symbol="TPS54331DR.kicad_sym">
    trait has_designator_prefix<prefix="U">
