  (pad "5" thru_hole circle (at 1.65 -3.30) (size 1.00 1.00) (drill 0.70) (layers "*.Cu" "*.Mask"))
  (pad "6" thru_hole circle (at -1.65 -1.10) (size 1.00 1.00) (drill 0.70) (layers "*.Cu" "*.Mask"))
  (pad "7" thru_hole circle (at -0.55 -1.10) (size 1.00 1.00) (drill 0.70) (layers "*.Cu" "*.Mask"))
  (pad "8" thru_hole circle (at 0.55 -1.10) (size 1.00 1.00) (drill 0.70) (layers "*.Cu" "*.Mask"))
  (pad "9" thru_hole circle (at 2.75 0.00) (size 1.00 1.00) (drill 0.70) (layers "*.Cu" "*.Mask"))
  (pad "10" thru_hole circle (at -2.75 0.00) (size 1.50 1.50) (drill 1.00) (layers "*.Cu" "*.Mask"))
