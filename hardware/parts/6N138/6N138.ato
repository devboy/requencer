# 6N138 — High-Speed Optocoupler, DIP-8
# LCSC: C571211
# Used for MIDI input isolation

component _6N138:
    signal NC1 ~ pin 1
    signal ANODE ~ pin 2
    signal CATHODE ~ pin 3
    signal NC4 ~ pin 4
    signal GND ~ pin 5
    signal VO ~ pin 6
    signal VE ~ pin 7
    signal VCC ~ pin 8

    designator_prefix = "U"
