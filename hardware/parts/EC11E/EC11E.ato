# EC11E — Alps Rotary Encoder with Push Switch, Through-Hole
# Quadrature output (A/B) + momentary push switch
# Footprint: standard KiCad library EC11E

component EC11E:
    signal A ~ pin 1
    signal GND_ENC ~ pin 2
    signal B ~ pin 3
    signal SW1 ~ pin 4
    signal SW2 ~ pin 5

    designator_prefix = "ENC"
